# 币安服务配置

# 币安 API 密钥（请填入你的真实密钥）
# 从 https://www.binance.com/zh-CN/my/api-management 获取
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here  # 仅 HMAC 签名需要

# 签名方式: ed25519, rsa, hmac
BINANCE_SIGNATURE_TYPE=ed25519

# 私钥路径（ED25519/RSA 签名需要）
BINANCE_PRIVATE_KEY_PATH=/path/to/private_key.pem
BINANCE_FUTURES_PRIVATE_KEY_PATH=/path/to/private_key.pem

# 数据库配置
DATABASE_HOST=timescale-db
DATABASE_PORT=5432
DATABASE_NAME=trading_db
DATABASE_USER=dbuser
DATABASE_PASSWORD=pass

# 代理配置（可选）
CLASH_PROXY_HTTP_URL=http://clash-proxy:7890
CLASH_PROXY_WS_URL=http://clash-proxy:7890

# 日志级别
LOG_LEVEL=INFO
